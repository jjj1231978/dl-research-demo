# Phase 0 — Skeleton & Data Foundation

# Local secrets — NEVER commit
.env
.env.local
.env.*.local

# Streamlit local secrets
.streamlit/secrets.toml

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Virtual environments
.venv/
venv/
env/

# Build artifacts
dist/
build/
*.egg

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Model checkpoints under dev — committed checkpoints go in data/pretrained/ explicitly
*.pt
*.pth
!data/pretrained/*.pt
!data/pretrained/*.pth

# Modal local state (just in case)
.modal/

# Fetched / derived data parquets — re-generated by scripts/fetch_*.py and
# scripts/run_backtests.py. Excluded by default to keep arbitrary developer
# downloads out of git; the two parquets the live app needs are whitelisted
# below (LFS-tracked via .gitattributes).
data/*.parquet
data/*.parquet.json
data/backtests/*.parquet
data/backtests/*.parquet.json

# Whitelist: input data the HF Space app needs to render Tab 1 + Tab 4.
!data/cme_futures.parquet
!data/cme_futures.parquet.json
!data/etf_basket.parquet
!data/etf_basket.parquet.json
!data/sp500_20.parquet
!data/sp500_20.parquet.json
# Phase 3: ship the small demo slice; the full FI-2010 parquet is dev-machine + Modal Volume only.
!data/lob_fi2010_demo.parquet
!data/backtests/momentum_results.parquet
!data/backtests/momentum_results.parquet.json
!data/backtests/portfolio_results.parquet
!data/backtests/portfolio_results.parquet.json
!data/backtests/lob_results.parquet
!data/backtests/lob_results.parquet.json
