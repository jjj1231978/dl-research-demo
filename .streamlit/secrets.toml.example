# Example .streamlit/secrets.toml — copy to .streamlit/secrets.toml for local
# Streamlit-secrets-style config. The live app prefers os.environ.get over
# st.secrets for local/HF symmetry (see Project_brief.md §15.4), so this file
# is illustrative rather than load-bearing.

FMP_API_KEY = "your_premium_key_here"
