# Deep Finance Showcase — local environment variables
#
# Copy this file to .env and fill in your values. .env is gitignored.

# FMP Premium API key — required by scripts/fetch_data.py.
# Get one at https://site.financialmodelingprep.com/developer/docs/pricing
FMP_API_KEY=your_premium_key_here

# Optional: relocate the parquet output directory to your existing data lake.
# Default (when unset): ./data/ relative to the repo root.
# When set, scripts/fetch_data.py writes parquets there and the live app reads from there.
# The bundled CSV fallbacks (data/aapl.csv, data/portfolio_data.csv) are not affected.
# DEEP_FINANCE_DATA_DIR=~/data_lake/deep-finance/
